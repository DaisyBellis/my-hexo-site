<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= config.title %></title>

  <!-- 法文古典衬线体 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&display=swap" rel="stylesheet">

  <!-- 中文字体 -->
  <link href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css" rel="stylesheet">

  <link rel="stylesheet" href="<%- url_for('/css/style.css') %>?v=12">
</head>
<body>
  <!-- 第一页：法文 -->
  <div id="page1" class="page">
    <p class="fr-text">UN JOUR<br>JE SERAI DE RETOUR<br>PRÈS DE TOI</p>
    <div id="hint1" class="hint">click <span class="arrow">↓</span></div>
  </div>

  <!-- 第二页：中文 -->
  <div id="page2" class="page hidden">
    <p class="zh-text">总有一天我会回到你身边</p>
    <div id="hint2" class="hint">click <span class="arrow">↓</span></div>
  </div>

  <canvas id="fire-canvas"></canvas>

  <script src="<%- url_for('/js/burn.js') %>"></script>
</body>
</html>